# 複製此檔案為 .env 並填入真實值

# 應用設定
DEBUG=false

# 允許的前端 Origin（逗號分隔）
# 例: ALLOWED_ORIGINS=["https://your-app.vercel.app","http://localhost:5173"]

# Supabase PostgreSQL（可選）
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# Redis 快取（可選）
REDIS_URL=redis://localhost:6379

# Finnhub API Key（免費申請：https://finnhub.io）
FINNHUB_API_KEY=your_finnhub_api_key_here

# Fugle Market Data API（台股歷史 K 線，申請：https://developer.fugle.tw）
FUGLE_API_KEY=your_fugle_api_key_here

# 無風險利率（自行調整）
RISK_FREE_RATE=0.053
RISK_FREE_RATE_TW=0.015
